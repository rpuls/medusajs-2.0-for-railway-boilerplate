# Your Medusa backend, should be updated to where you are hosting your server. Remember to update CORS settings for your server.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Your store URL, should be updated to where you are hosting your storefront.
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Your preferred default region. When middleware cannot determine the user region from the request IP, this will be used instead.
NEXT_PUBLIC_DEFAULT_REGION=us

# Hostname that product images are served from (optional).
# Set this to the host of your S3-compatible storage, e.g. my-bucket.storage.railway.app
# or localhost:9004 when using the local docker-compose MinIO service.
# NEXT_PUBLIC_MEDIA_HOSTNAME=your-bucket-hostname
# Legacy alias, still supported:
# NEXT_PUBLIC_MINIO_ENDPOINT=bucket-production-eaeb.up.railway.app

# MeiliSearch Configuration
# The URL of your MeiliSearch instance (default: http://localhost:7700 or auto-configured on Railway)
NEXT_PUBLIC_SEARCH_ENDPOINT=http://localhost:7700

# Your MeiliSearch SEARCH-ONLY key. This value is exposed to the browser -
# never put an admin or master key here.
# Leave it empty and set MEILISEARCH_API_KEY (server-side master key, e.g. the
# docker-compose key local_meilisearch_master_key) instead to let the launcher
# fetch a search-only key automatically - this is how Railway configures it.
NEXT_PUBLIC_SEARCH_API_KEY=
# MEILISEARCH_API_KEY=local_meilisearch_master_key

# The name of the index in MeiliSearch (matches backend configuration)
NEXT_PUBLIC_INDEX_NAME=products
