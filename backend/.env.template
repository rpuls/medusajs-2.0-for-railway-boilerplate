NODE_ENV=development
# REDIS_URL=redis://localhost:6379 # Optional - falls back to simulated redis. The local docker-compose redis matches this URL.
ADMIN_CORS=http://localhost:7000,http://localhost:7001,https://docs.medusajs.com
STORE_CORS=http://localhost:8000,https://docs.medusajs.com
AUTH_CORS=http://localhost:7000,http://localhost:7001,https://docs.medusajs.com
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=postgres://postgres:postgres@localhost:5432/medusa # Make sure this database exists - or change connection string to an online database. The local docker-compose postgres matches this URL.

MEDUSA_ADMIN_EMAIL=admin@yourmail.com
MEDUSA_ADMIN_PASSWORD=supersecret

STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

SENDGRID_API_KEY=
SENDGRID_FROM=

# S3-compatible file storage (optional - falls back to local storage)
# Works with Railway buckets, AWS S3, Cloudflare R2, MinIO and any other S3-compatible provider.
# The bucket must already exist and allow public read access (bucket policy) for product images.
# The commented values below match the MinIO service from the local docker-compose setup.
# S3_FILE_URL=http://localhost:9004/medusa-media # Public base URL that files are served from
# S3_ACCESS_KEY_ID=medusa
# S3_SECRET_ACCESS_KEY=supersecret
# S3_REGION=us-east-1 # Use 'auto' for Railway buckets and Cloudflare R2
# S3_BUCKET=medusa-media
# S3_ENDPOINT=http://localhost:9004
# S3_FORCE_PATH_STYLE=true # Required for MinIO; leave unset for AWS S3 and Railway buckets
# S3_ACL= # Leave unset for Railway buckets/R2/new AWS buckets; set to public-read only for legacy ACL-based buckets

# Meilisearch Configuration (Optional)
# The commented values below match the meilisearch service from the local docker-compose setup.
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_MASTER_KEY=local_meilisearch_master_key # Required if MEILISEARCH_ADMIN_KEY is not set
# MEILISEARCH_ADMIN_KEY= # Optional - if not set, will be fetched using master key when running `pnpm ib`
